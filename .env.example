BOT_TOKEN=123456:replace-me
ALLOWED_USER_IDS=123456789

MONITORING_BOT_IMAGE=monitoring-bot:debian-amd64
MONITOR_BOT_VERSION=local
MONITOR_SERVER_NAME=server-name
MONITOR_TIMEZONE=Europe/Moscow
LOG_LEVEL=INFO

MONITOR_DOCKER_BASE_URL=unix:///var/run/docker.sock
MONITOR_DOCKER_PROJECT=
MONITOR_EXCLUDED_SERVICES=monitoring-bot

MONITOR_RESTART_TIMEOUT_SECONDS=15
MONITOR_DEFAULT_LOGS_TAIL=200
MONITOR_MAX_LOGS_TAIL=1000
MONITOR_MAX_INLINE_LOG_CHARS=3000

MONITOR_COMMAND_TIMEOUT_SECONDS=20
MONITOR_COMMAND_MAX_OUTPUT_CHARS=12000

MONITOR_BACKUP_SOURCE_DIR=/root
MONITOR_BACKUP_TARGET_DIR=/backup
MONITOR_BACKUP_TIMEOUT_SECONDS=600

MONITOR_CLEANUP_PATH=/opt/monitoring-bot
MONITOR_CLEANUP_TIMEOUT_SECONDS=60

MONITOR_ALERT_CHAT_IDS=
MONITOR_ALERT_POLL_SECONDS=30
MONITOR_NOTIFY_ON_STARTUP=false
MONITOR_SYSTEM_ALERT_THRESHOLD_PERCENT=90

MONITOR_SYSTEM_PROC_PATH=/host/proc
MONITOR_SYSTEM_DISK_PATH=/hostfs
MONITOR_SYSTEM_DISK_LABEL=/
MONITOR_SYSTEM_CACHE_SECONDS=5
MONITOR_SYSTEM_AVERAGE_WINDOW_SECONDS=300

MONITOR_LOGIN_ALERTS_ENABLED=true
MONITOR_LOGIN_POLL_SECONDS=5
MONITOR_LOGIN_LOG_PATHS=/hostfs/var/log/auth.log,/hostfs/var/log/secure
MONITOR_LOGIN_WTMP_PATHS=/hostfs/var/log/wtmp
MONITOR_LOGIN_UTMP_PATHS=/hostfs/run/utmp,/hostfs/var/run/utmp
